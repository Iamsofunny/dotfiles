{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "cssPriority": "user",
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "notification-window-width": 400,
  "notification-icon-size": 48,
  "notification-body-image-height": 120,
  "notification-body-image-width": 200,
  "notification-2fa-action": true,
  "notification-inline-replies": true,
  "control-center-width": 420,
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "hide-on-clear": true,
  "hide-on-action": true,
  "image-visibility": "when-available",
  "transition-time": 150,
  "widgets": [
    "inhibitors",
    "title",
    "dnd",
    "buttons-grid",
    "volume",
    "backlight",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "Clear All",
      "clear-all-button": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do not disturb"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰖩",
          "type": "toggle",
          "command": "sh -c 'if [ \"$SWAYNC_TOGGLE_STATE\" = true ]; then nmcli radio wifi on; else nmcli radio wifi off; fi'",
          "update-command": "sh -c 'if [ \"$(nmcli radio wifi)\" = enabled ]; then echo true; else echo false; fi'"
        },
        {
          "label": "󰂯",
          "type": "toggle",
          "command": "sh -c 'if [ \"$SWAYNC_TOGGLE_STATE\" = true ]; then bluetoothctl power on; else bluetoothctl power off; fi'",
          "update-command": "sh -c 'if bluetoothctl show | grep -q \"Powered: yes\"; then echo true; else echo false; fi'"
        },
        {
          "label": "󰍬",
          "type": "toggle",
          "command": "sh -c 'if [ \"$SWAYNC_TOGGLE_STATE\" = true ]; then wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 0; else wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 1; fi'",
          "update-command": "sh -c 'if wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -q MUTED; then echo false; else echo true; fi'"
        },
        {
          "label": "󰌾",
          "command": "loginctl lock-session"
        }
      ]
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": true,
      "expand-button-label": "",
      "collapse-button-label": ""
    },
    "backlight": {
      "label": "󰃟",
      "subsystem": "backlight"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 8
    }
  }
}
