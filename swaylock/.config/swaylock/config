# PLACEHOLDER — replace with your real swaylock theming.
# Committed / read-only (set-and-forget): changes need a nixos-rebuild switch.
# Note: -f (daemonize) is passed at the call sites (swayidle config, niri
# bind), not set here.

ignore-empty-password
show-failed-attempts
indicator-caps-lock

# Minimal dark look, roughly matching the Waybar palette:
color=0f1117
indicator-radius=100
indicator-thickness=8
inside-color=0f1117
ring-color=1a6fd4
key-hl-color=4a9eff
text-color=9aaec8
inside-wrong-color=2a1020
ring-wrong-color=ff5555
inside-ver-color=0d1828
ring-ver-color=4a9eff
